{
  "expo": {
    "name": "MindJournal AI",
    "slug": "mindjournal-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F6F4FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindjournalai.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow MindJournal AI to turn Quick Entries into text.",
        "NSMicrophoneUsageDescription": "Allow MindJournal AI to use the microphone for Quick Entries.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mindjournalai.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow MindJournal AI to use the microphone for Quick Entries.",
          "speechRecognitionPermission": "Allow MindJournal AI to turn Quick Entries into text.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.as"
          ]
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "e3df15c5-d73e-4bec-a4a6-a59c97cbabe0"
      }
    }
  }
}
